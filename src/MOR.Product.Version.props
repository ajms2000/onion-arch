<Project>

	<!--https://semver.org/spec/v2.0.0-rc.1.html-->
	<!--WARNING: DO NOT EDIT BELOW CONTENT!-->

	<Import Project="$(MSBuildThisFileDirectory)MOR.Version.props" />

	<!--****** GENERAL ******-->

	<PropertyGroup>
		<!--Represents current product version (MAJOR.MINOR.PATCH) without pre-release tag.-->
		<_VRVersionProduct>$(_VRVersionBase).$(_VRVersionPatch)</_VRVersionProduct>
	</PropertyGroup>


	<!--****** PRE-RELEASES ******-->

	<!--Regular delivery-->
	<PropertyGroup Condition="'$(_VRVersionPreReleaseTag)' == ''">
		<!--The release version including MAJOR.MINOR.PATCH.-->
		<_VRVersionRelease>$(_VRVersionProduct)</_VRVersionRelease>
	</PropertyGroup>

	<!--Pre-release delivery-->
	<PropertyGroup Condition="'$(_VRVersionPreReleaseTag)' != ''">
		<!--The release version including MAJOR.MINOR.PATCH-{pre-release tag}-->
		<_VRVersionRelease>$(_VRVersionProduct)-$(_VRVersionPreReleaseTag)</_VRVersionRelease>
	</PropertyGroup>


	<!--****** PACKAGE ******-->

	<PropertyGroup>
		<!--This is used for naming build packages.-->
		<_VRVersionPkg>$(_VRVersionProduct)</_VRVersionPkg>
	</PropertyGroup>

</Project>
